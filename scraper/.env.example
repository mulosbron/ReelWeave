# Arweave IMDB Scraper Configuration
# This file contains environment variables for the IMDB scraper

# Arweave configuration
ARWEAVE_HOST=arweave.net
ARWEAVE_PORT=443
ARWEAVE_PROTOCOL=https

# Scraper settings
SCRAPE_LIMIT=250  # Number of movies to scrape from IMDB Top 250
DETAILS_LIMIT=50  # Number of movies to fetch detailed information for
SCRAPE_INTERVAL=86400000  # Scrape interval in milliseconds (24 hours)

# Output settings
SAVE_JSON=true  # Whether to save scraped data to JSON files
